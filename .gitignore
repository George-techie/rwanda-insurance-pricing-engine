.env
.env.*
!.env.example

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- Virtual environments --------------------------------------------------
.venv/
venv/
env/

# --- Generated vector store (rebuild with `python -m assar.ingest`) ---------
data/chroma/

# --- Scratch / exports -----------------------------------------------------
*.xlsx
data/*.csv

# --- Source manual (third-party IP — add deliberately if you want rebuilds) -
# *.pdf

# --- OS / editor -----------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/

# NOTE: data/assar.db and data/corpus.md ARE committed on purpose, so the repo
