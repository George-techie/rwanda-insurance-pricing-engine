# ---- LLM backend --------------------------------------------------------
# Choose one: groq (default, recommended for the demo) | ollama (local Qwen) | hf
LLM_BACKEND=groq

# Groq (https://console.groq.com/keys) — fast, free tier, no local GPU needed
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Qwen via Ollama (run `ollama pull qwen2.5:7b-instruct` first)
# LLM_BACKEND=ollama
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1

# Hugging Face Inference Providers (https://huggingface.co/settings/tokens)
# LLM_BACKEND=hf
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---- Embeddings (local, no API) -----------------------------------------
# Default is English-optimised + small. For Kinyarwanda/French use BAAI/bge-m3.
EMBED_MODEL=BAAI/bge-small-en-v1.5
