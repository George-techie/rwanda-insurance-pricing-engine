# ---- LLM backend --------------------------------------------------------
# Choose one: groq (default, recommended for the demo) | ollama (local Qwen) | hf
LLM_BACKEND=groq

# Groq (https://console.groq.com/keys) — fast, free tier, no local GPU needed
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Qwen via Ollama (run `ollama pull qwen2.5:7b-instruct` first)
# LLM_BACKEND=ollama
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1

# Hugging Face Inference Providers (https://huggingface.co/settings/tokens)
# LLM_BACKEND=hf
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---- Embeddings (local, no API) -----------------------------------------
# Default is English-optimised. For Kinyarwanda/French use BAAI/bge-m3.
#   bge-small (384-d, fastest) < bge-base (768-d, default) < bge-large (1024-d)
# Changing this REQUIRES a re-ingest: python -m assar.rag.ingest
EMBED_MODEL=BAAI/bge-base-en-v1.5

# Chunking (re-ingest after changing)
CHUNK_TARGET=1600
CHUNK_OVERLAP=200

# ---- Retrieval pipeline (no re-ingest needed) ---------------------------
# See docs/RETRIEVAL.md. Measure changes with: python -m assar.rag.eval --compare
RAG_HYBRID=1          # dense + BM25 keyword search fused with RRF
RAG_RERANK=1          # cross-encoder reranks the shortlist (biggest precision win)
RAG_EXPANSION=0       # LLM multi-query expansion (helps recall, costs tokens)
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_CANDIDATES=20     # shortlist size from each first-stage retriever
RAG_RRF_K=60          # RRF damping constant
RAG_EXPANSION_N=3     # paraphrases per query when expansion is on

# ---- CoverSoko underwriting backend (optional) --------------------------
# When set, the assistant exposes a `quote_property` tool that prices via the
# CoverSoko API instead of the local calculators. Unset = local-only (default).
# See docs/COVERSOKO_INTEGRATION.md.
# COVERSOKO_API_URL=http://localhost:3500
# COVERSOKO_OWNER_ID=          # insurer UUID for tariff overrides (the tenant)
# COVERSOKO_API_KEY=           # optional bearer token
# COVERSOKO_TIMEOUT=15
